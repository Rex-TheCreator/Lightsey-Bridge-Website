---
import "../styles/global.css";
---

    <div class="flex flex-col gap-2 lg:gap-6 mx-4 mt-8 lg:mx-32">
        <div class="flex">
            <div class="flex-1 text-4xl md:text-5xl text-white text-center md:text-start bg-inclusiveOrange-100 p-4 rounded-2xl">{Astro.props.title}</div>
        </div>
        <div class="flex justify-center md:justify-start">
            <div class="text-2xl md:text-3xl text-white bg-inclusiveOrange-100 md:mx-16 p-4 rounded-2xl">Instructions:</div>
        </div>
        <div class="flex">
            <div class="flex-1 text-2xl text-white bg-inclusiveOrange-300 md:mx-32 p-4 rounded-2xl">
                <slot/>
            </div>
        </div>
    </div>